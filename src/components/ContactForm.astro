---
interface Props {
  heading?: string;
  description?: string;
  sectionId?: string;
}

const {
  heading = 'Contact',
  description = 'Send us your details and we will follow up with a quote.',
  sectionId = 'contact'
} = Astro.props;
---

<section id={sectionId} class="section" role="region" aria-labelledby={`${sectionId}Heading`}>
  <div class="container">
    <h2 id={`${sectionId}Heading`}>{heading}</h2>
    <p class="contact-description">{description}</p>
    <form id="contactForm" method="post" action="/__forms/contact" novalidate>
      <div class="form-group">
        <label for="name">Name <span aria-label="required">*</span></label>
        <input type="text" id="name" name="name" required aria-required="true" aria-describedby="nameError" />
        <span id="nameError" class="error-message"></span>
      </div>
      <div class="form-group">
        <label for="email">Email <span aria-label="required">*</span></label>
        <input type="email" id="email" name="email" required aria-required="true" aria-describedby="emailError" />
        <span id="emailError" class="error-message"></span>
      </div>
      <div class="form-group">
        <label for="phone">Phone (optional)</label>
        <input type="tel" id="phone" name="phone" aria-describedby="phoneError" />
        <span id="phoneError" class="error-message"></span>
      </div>
      <div class="form-group">
        <label for="message">Message <span aria-label="required">*</span></label>
        <textarea id="message" name="message" rows="5" required aria-required="true" aria-describedby="messageError"></textarea>
        <span id="messageError" class="error-message"></span>
      </div>
      <input type="hidden" name="owner_email" value="eitanwaxman@gmail.com" />
      <input type="text" name="_hp" style="display:none" autocomplete="off" tabindex="-1" />
      <button type="submit" id="submitBtn" class="btn btn-primary" aria-busy="false">Submit</button>
    </form>
    <div id="responseMessage" role="alert" aria-live="polite"></div>
  </div>
</section>
