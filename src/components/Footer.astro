---
const base = import.meta.env.BASE_URL.replace(/\/$/, '') || '';
---

<footer role="contentinfo">
  <div class="footer-content">
    <div class="footer-section">
      <h3>Quick Links</h3>
      <ul>
        <li><a href={base + '/#services'}>Services</a></li>
        <li><a href={base + '/#about'}>About</a></li>
        <li><a href={base + '/#contact'}>Contact</a></li>
      </ul>
    </div>
    <div class="footer-section">
      <h3>Business Name</h3>
      <p>Placeholder Local Cleaning</p>
      <p>Professional, insured cleaning services.</p>
      <small>Licensed • Insured • Satisfaction guaranteed</small>
    </div>
    <div class="footer-section">
      <h3>Contact</h3>
      <ul>
        <li>Email: eitanwaxman@gmail.com</li>
        <li>Hours: Mon-Sat, 8:00 AM - 6:00 PM</li>
        <li>Service Area: Local neighborhoods and small offices</li>
      </ul>
    </div>
  </div>
  <div class="footer-bottom">
    <p>&copy; <span id="year">2026</span> Placeholder Local Cleaning. All rights reserved.</p>
  </div>
</footer>
