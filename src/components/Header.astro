---
interface Props {
  current?: 'home' | 'about' | 'thank-you';
}

const { current } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '') || '';
---

<header role="banner">
  <nav role="navigation" aria-label="Main navigation">
    <a href={base + '/'} class="logo">🏢 My Site</a>
    <button class="hamburger" id="hamburgerMenu" aria-label="Toggle navigation menu" aria-expanded="false" aria-controls="navMenu">
      <span></span>
      <span></span>
      <span></span>
    </button>
    <ul id="navMenu" class="nav-menu">
      <li><a href={base + '/'} aria-current={current === 'home' ? 'page' : undefined}>Home</a></li>
      <li><a href={base + '/about/'} aria-current={current === 'about' ? 'page' : undefined}>About Us</a></li>
      <li><a href={base + '/#features'}>Features</a></li>
      <li><a href={base + '/#testimonials'}>Testimonials</a></li>
      <li><a href={base + '/#contact'}>Contact</a></li>
    </ul>
  </nav>
</header>
