---
interface Props {
  current?: 'home' | 'about' | 'thank-you';
}

const { current } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '') || '';
---

<header role="banner">
  <nav role="navigation" aria-label="Main navigation">
    <a href={base + '/'} class="logo" aria-label="Homepage">
      <span class="logo-mark" aria-hidden="true">Logo Placeholder</span>
    </a>
    <ul id="navMenu" class="nav-menu">
      <li><a href={base + '/'} aria-current={current === 'home' ? 'page' : undefined}>Home</a></li>
      <li><a href={base + '/#services'}>Services</a></li>
      <li><a href={base + '/#about'}>About</a></li>
      <li><a href={base + '/#testimonials'}>Testimonials</a></li>
      <li><a href={base + '/#contact'}>Contact</a></li>
    </ul>
    <div class="header-cta">
      <a href={base + '/#contact'} class="btn btn-primary">Get a Quote</a>
    </div>
  </nav>
</header>
