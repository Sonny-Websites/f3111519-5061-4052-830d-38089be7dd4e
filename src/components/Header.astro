---
interface Props {
  current?: 'home' | 'services' | 'about' | 'contact' | 'thank-you';
}

const { current } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '') || '';
---

<header role="banner">
  <nav role="navigation" aria-label="Main navigation">
    <a href={base + '/'} class="logo" aria-label="Homepage">
      <span class="logo-mark" aria-hidden="true">Logo Placeholder</span>
    </a>
    <ul id="navMenu" class="nav-menu">
      <li><a href={base + '/'} aria-current={current === 'home' ? 'page' : undefined}>Home</a></li>
      <li><a href={base + '/services'} aria-current={current === 'services' ? 'page' : undefined}>Services</a></li>
      <li><a href={base + '/services/residential-cleaning'}>Residential Cleaning</a></li>
      <li><a href={base + '/services/commercial-cleaning'}>Commercial Cleaning</a></li>
      <li><a href={base + '/services/deep-cleaning'}>Deep Cleaning</a></li>
      <li><a href={base + '/services/move-cleaning'}>Move-In / Move-Out Cleaning</a></li>
      <li><a href={base + '/services/carpet-cleaning'}>Carpet Cleaning</a></li>
      <li><a href={base + '/about'} aria-current={current === 'about' ? 'page' : undefined}>About</a></li>
      <li><a href={base + '/#testimonials'}>Testimonials</a></li>
      <li><a href={base + '/contact'} aria-current={current === 'contact' ? 'page' : undefined}>Contact</a></li>
    </ul>
    <div class="header-cta">
      <a href={base + '/contact#contactFormSection'} class="btn btn-primary">Get a Quote</a>
    </div>
  </nav>
</header>
