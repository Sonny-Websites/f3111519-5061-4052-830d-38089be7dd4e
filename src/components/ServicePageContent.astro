---
import type { ServiceItem } from '../data/services';

interface Props {
  service: ServiceItem;
}

const { service } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '') || '';
---

<section class="hero service-hero" role="region" aria-labelledby="serviceHeroHeading">
  <div class="container">
    <div class="hero-content">
      <h1 id="serviceHeroHeading">{service.name}</h1>
      <p class="hero-subtitle">{service.shortDescription}</p>
    </div>
  </div>
</section>

<section class="section" role="region" aria-labelledby="overviewHeading">
  <div class="container">
    <h2 id="overviewHeading">Overview</h2>
    <article class="content-card">
      {service.overview.map((paragraph) => <p>{paragraph}</p>)}
    </article>
  </div>
</section>

<section class="section" role="region" aria-labelledby="includedHeading">
  <div class="container">
    <h2 id="includedHeading">What&apos;s Included</h2>
    <article class="content-card">
      <ul class="checklist">
        {service.checklist.map((item) => <li>{item}</li>)}
      </ul>
    </article>
  </div>
</section>

<section class="section" role="region" aria-labelledby="pricingHeading">
  <div class="container">
    <h2 id="pricingHeading">Pricing</h2>
    <article class="content-card">
      <p class="placeholder-label">Placeholder: Pricing examples</p>
      <ul class="pricing-list">
        {service.pricing.map((item) => <li>{item}</li>)}
      </ul>
    </article>
  </div>
</section>

<section class="section" role="region" aria-labelledby="galleryHeading">
  <div class="container">
    <h2 id="galleryHeading">Gallery</h2>
    <article class="content-card">
      <p class="gallery-placeholder">Gallery placeholder - no photos provided.</p>
    </article>
  </div>
</section>

<section class="section" role="region" aria-labelledby="quoteHeading">
  <div class="container">
    <article class="content-card cta-card">
      <h2 id="quoteHeading">Ready to get started?</h2>
      <p>Use our site-wide contact form to request a tailored quote for this service.</p>
      <a href={`${base}/contact#contactFormSection`} class="btn btn-primary">Request a Quote</a>
    </article>
  </div>
</section>
