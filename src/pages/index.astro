---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'LocalBusiness',
  name: 'Placeholder Local Cleaning',
  url: 'https://example.com',
  description: 'Professional, insured cleaning for homes and small offices.',
  contactPoint: {
    '@type': 'ContactPoint',
    contactType: 'Customer Service',
    email: 'eitanwaxman@gmail.com',
    availableLanguage: ['en']
  }
};
---

  <BaseLayout
  title="Placeholder Local Cleaning"
  description="Reliable local cleaners for homes and small offices."
  ogTitle="Reliable Local Cleaners — Book Today"
  ogDescription="Professional, insured cleaning for homes and small offices."
  jsonLd={jsonLd}
>
  <Header current="home" />
  <section class="hero" role="region" aria-labelledby="heroHeading">
    <div class="container">
      <div class="hero-content">
        <h1 id="heroHeading">We make your home spotless</h1>
        <p class="hero-subtitle">Professional residential and commercial cleaning.</p>
        <small class="hero-trust">Licensed • Insured • Satisfaction guaranteed</small>
        <div class="hero-buttons">
          <a href="#contact" class="btn btn-primary">Get a Quote</a>
          <a href="#services" class="btn btn-secondary">Our Services</a>
        </div>
      </div>
      <div class="media-placeholder" aria-hidden="true">
        Hero Image/Video Placeholder
      </div>
    </div>
  </section>

  <section id="services" class="section" role="region" aria-labelledby="servicesHeading">
    <div class="container">
      <h2 id="servicesHeading">Our services</h2>
      <div class="card-stack">
        <article class="service-card">
          <div class="service-media-placeholder" aria-hidden="true">Image/Video Placeholder</div>
          <h3>Standard Clean</h3>
          <p>Routine weekly or bi-weekly cleaning for kitchens, bathrooms, bedrooms, and living areas.</p>
        </article>
        <article class="service-card">
          <div class="service-media-placeholder" aria-hidden="true">Image/Video Placeholder</div>
          <h3>Deep Clean</h3>
          <p>Detailed top-to-bottom cleaning with extra attention to buildup, baseboards, and high-touch surfaces.</p>
        </article>
        <article class="service-card">
          <div class="service-media-placeholder" aria-hidden="true">Image/Video Placeholder</div>
          <h3>Move-out Clean</h3>
          <p>Comprehensive cleaning for empty homes or apartments before move-out or handover.</p>
        </article>
      </div>
    </div>
  </section>

  <section id="about" class="section" role="region" aria-labelledby="aboutHeading">
    <div class="container">
      <h2 id="aboutHeading">About</h2>
      <p class="about-copy">We deliver dependable, detail-focused cleaning backed by experienced professionals, insurance coverage, and trusted service standards that help homeowners and small offices feel confident every visit.</p>
    </div>
  </section>

  <section id="testimonials" class="section" role="region" aria-labelledby="testimonialsHeading">
    <div class="container">
      <h2 id="testimonialsHeading">Testimonials</h2>
      <div class="card-stack">
        <article class="testimonial-card">
          <p>"Consistent quality and great communication every time."</p>
          <p class="testimonial-author">Satisfied Customer</p>
        </article>
        <article class="testimonial-card">
          <p>"Our office has never looked better. Reliable and efficient team."</p>
          <p class="testimonial-author">Satisfied Customer</p>
        </article>
        <article class="testimonial-card">
          <p>"Move-out cleaning was thorough and stress-free."</p>
          <p class="testimonial-author">Satisfied Customer</p>
        </article>
      </div>
    </div>
  </section>

  <section id="contact" class="section" role="region" aria-labelledby="contactHeading">
    <div class="container">
      <h2 id="contactHeading">Contact</h2>
      <p class="contact-description">Send us your details and we will follow up with a quote.</p>
      <form id="contactForm" method="post" action="/__forms/contact" novalidate>
        <div class="form-group">
          <label for="name">Name <span aria-label="required">*</span></label>
          <input type="text" id="name" name="name" required aria-required="true" aria-describedby="nameError" />
          <span id="nameError" class="error-message"></span>
        </div>
        <div class="form-group">
          <label for="email">Email <span aria-label="required">*</span></label>
          <input type="email" id="email" name="email" required aria-required="true" aria-describedby="emailError" />
          <span id="emailError" class="error-message"></span>
        </div>
        <div class="form-group">
          <label for="phone">Phone (optional)</label>
          <input type="tel" id="phone" name="phone" aria-describedby="phoneError" />
          <span id="phoneError" class="error-message"></span>
        </div>
        <div class="form-group">
          <label for="message">Message <span aria-label="required">*</span></label>
          <textarea id="message" name="message" rows="5" required aria-required="true" aria-describedby="messageError"></textarea>
          <span id="messageError" class="error-message"></span>
        </div>
        <input type="hidden" name="owner_email" value="eitanwaxman@gmail.com" />
        <input type="text" name="_hp" style="display:none" autocomplete="off" tabindex="-1" />
        <button type="submit" id="submitBtn" class="btn btn-primary" aria-busy="false">Submit</button>
      </form>
      <div id="responseMessage" role="alert" aria-live="polite"></div>
    </div>
  </section>
  <Footer />
</BaseLayout>
