---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ContactForm from '../components/ContactForm.astro';
import { services } from '../data/services';

const base = import.meta.env.BASE_URL.replace(/\/$/, '') || '';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'LocalBusiness',
  name: 'Placeholder Local Cleaning',
  url: 'https://example.com',
  description: 'Professional, insured cleaning for homes and small offices.',
  contactPoint: {
    '@type': 'ContactPoint',
    contactType: 'Customer Service',
    email: 'eitanwaxman@gmail.com',
    availableLanguage: ['en']
  }
};
---

  <BaseLayout
  title="Placeholder Local Cleaning"
  description="Reliable local cleaners for homes and small offices."
  ogTitle="Reliable Local Cleaners — Book Today"
  ogDescription="Professional, insured cleaning for homes and small offices."
  jsonLd={jsonLd}
>
  <Header current="home" />
  <section class="hero" role="region" aria-labelledby="heroHeading">
    <div class="container">
      <div class="hero-content">
        <h1 id="heroHeading">We make your home spotless</h1>
        <p class="hero-subtitle">Professional residential and commercial cleaning.</p>
        <small class="hero-trust">Licensed • Insured • Satisfaction guaranteed</small>
        <div class="hero-buttons">
          <a href={`${base}/contact#contactFormSection`} class="btn btn-primary">Get a Quote</a>
          <a href={`${base}/services`} class="btn btn-secondary">Our Services</a>
        </div>
      </div>
      <div class="hero-media">
        <img
          src="https://cdn.prod.website-files.com/60ff934f6ded2d17563ab9dd/61392e6b85cca9544875c7d2_shutterstock_589490129.jpeg"
          alt="Cleaning professional preparing a spotless interior"
          loading="eager"
          width="1280"
          height="720"
        />
      </div>
    </div>
  </section>

  <section id="services" class="section" role="region" aria-labelledby="servicesHeading">
    <div class="container">
      <h2 id="servicesHeading">Our services</h2>
      <div class="card-stack">
        {services.map((service) => (
          <article class="service-card">
            <h3>{service.name}</h3>
            <p>{service.shortDescription}</p>
            <a href={`${base}/services/${service.slug}`} class="btn btn-secondary">View Service Page</a>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section id="about" class="section" role="region" aria-labelledby="aboutHeading">
    <div class="container">
      <h2 id="aboutHeading">About</h2>
      <p class="about-copy">We deliver dependable, detail-focused cleaning backed by experienced professionals, insurance coverage, and trusted service standards that help homeowners and small offices feel confident every visit.</p>
    </div>
  </section>

  <section id="testimonials" class="section" role="region" aria-labelledby="testimonialsHeading">
    <div class="container">
      <h2 id="testimonialsHeading">Testimonials</h2>
      <div class="card-stack">
        <article class="testimonial-card">
          <p>"Consistent quality and great communication every time."</p>
          <p class="testimonial-author">Satisfied Customer</p>
        </article>
        <article class="testimonial-card">
          <p>"Our office has never looked better. Reliable and efficient team."</p>
          <p class="testimonial-author">Satisfied Customer</p>
        </article>
        <article class="testimonial-card">
          <p>"Move-out cleaning was thorough and stress-free."</p>
          <p class="testimonial-author">Satisfied Customer</p>
        </article>
      </div>
    </div>
  </section>

  <ContactForm />
  <Footer />
</BaseLayout>
