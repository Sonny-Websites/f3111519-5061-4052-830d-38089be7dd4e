---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import ServicePageContent from '../../components/ServicePageContent.astro';
import { services } from '../../data/services';

const service = services.find((item) => item.slug === 'residential-cleaning');
---

<BaseLayout
  title="Residential Cleaning — Placeholder Local Cleaning"
  description={service?.metaDescription}
  ogTitle="Residential Cleaning — Placeholder Local Cleaning"
  ogDescription={service?.metaDescription}
>
  <Header current="services" />
  {service && <ServicePageContent service={service} />}
  <Footer />
</BaseLayout>
