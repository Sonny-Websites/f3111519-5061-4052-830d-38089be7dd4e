---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const base = import.meta.env.BASE_URL.replace(/\/$/, '') || '';
---

<BaseLayout
  title="Thank You"
  description="Thank you for contacting us. We have received your message and will get back to you soon."
  ogTitle="Thank You for Your Message"
  ogDescription="Your message has been sent successfully. We will get back to you soon."
>
  <Header current="thank-you" />
  <section class="thank-you" role="main" aria-labelledby="thankHeading">
    <h1 id="thankHeading"><span style="color: #27ae60; font-size: 3rem;">✓</span><br />Thank You!</h1>
    <p>Your message has been sent successfully. We will get back to you soon.</p>
    <p style="color: #666; font-size: 0.95rem; margin-top: 1rem;">We appreciate you reaching out and will respond to your inquiry within 24 hours.</p>
    <a href={base + '/'} class="btn btn-primary" style="display: inline-block; margin-top: 2rem;">Back to Home</a>
  </section>
  <Footer />
</BaseLayout>
