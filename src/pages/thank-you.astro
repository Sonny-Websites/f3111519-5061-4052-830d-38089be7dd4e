---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const base = import.meta.env.BASE_URL.replace(/\/$/, '') || '';
---

<BaseLayout
  title="Thank You"
  description="Thank you for contacting us. We have received your message and will get back to you soon."
  ogTitle="Thank You for Your Message"
  ogDescription="Your message has been sent successfully. We will get back to you soon."
>
  <Header current="thank-you" />
  <section class="thank-you" role="main" aria-labelledby="thankHeading">
    <h1 id="thankHeading"><span class="thank-check">✓</span><br />Thank You!</h1>
    <p>Your message has been sent successfully. We will get back to you soon.</p>
    <p>We appreciate you reaching out and will respond to your inquiry within 24 hours.</p>
    <a href={base + '/'} class="btn btn-primary">Back to Home</a>
  </section>
  <Footer />
</BaseLayout>
